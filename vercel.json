{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install && python3 -m pip install -r requirements.txt || npm install",
  "outputDirectory": ".next",
  "functions": {
    "api/execute_scraper.py": {
      "runtime": "@vercel/python@3.1.0",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "build": {
    "env": {
      "PYTHON_VERSION": "3.12"
    }
  }
}